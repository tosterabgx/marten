---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const domain = Astro.site?.hostname ?? "localhost";
const linuxInstall = `curl -fsSL https://${domain}/install.sh | sh`;
const winInstall = `irm https://${domain}/install.ps1 | iex`;

const sections = [
  { id: "install", label: "Install" },
  { id: "usage", label: "Usage" },
];
---

<BaseLayout title="Marten Docs">
  <Nav />
  <main id="docs">
    <aside class="toc">
      <ul>
        {
          sections.map((section) => (
            <li>
              <a href={`#${section.id}`}>{section.label}</a>
            </li>
          ))
        }
      </ul>
    </aside>

    <div class="content">
      <h1>Documentation</h1>

      <section id="install">
        <h2>Install</h2>
        <p>Linux/MacOS:</p>
        <pre
          class="code-block"><span class="prompt">$</span> {linuxInstall}</pre>
        <p>Windows:</p>
        <pre class="code-block"><span class="prompt">$</span> {winInstall}</pre>
        <p>Or build from source with Go:</p>
        <pre
          class="code-block"><span class="prompt">$</span> go install github.com/tosterabgx/marten/cmd/marten@latest</pre>
      </section>

      <section id="usage">
        <h2>Usage</h2>
        <p>
          <code>marten tcp &lt;port&gt;</code> exposes a local TCP port through the
          tunnel:
        </p>
        <pre
          class="code-block"><span class="prompt">$</span> marten tcp 3000</pre>
        <p>
          marten prints back a remote address that anyone can use to reach your
          local port 3000.
        </p>
        <p>
          <code>marten http &lt;port&gt;</code> exposes a local port on an auto-generated
          HTTPS subdomain:
        </p>
        <pre
          class="code-block"><span class="prompt">$</span> marten http 3000</pre>
        <p>
          marten prints a URL like
          <code>https://lovely-panda.usemarten.tech</code>
          that proxies to your local port.
        </p>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  #docs {
    display: flex;
    align-items: flex-start;
    gap: 60px;
    padding: 50px 40px 90px;
  }

  .toc {
    position: sticky;
    top: 40px;
    flex: 0 0 160px;
  }

  .toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .toc a {
    color: #9b8e7c;
    text-decoration: none;
    font-size: 14px;
  }

  .toc a:hover {
    color: #edbb7e;
  }

  .content {
    flex: 1;
    min-width: 0;
    max-width: 680px;
  }

  h1 {
    font-family: var(--font-space-grotesk);
    font-weight: 300;
    font-size: 40px;
    margin: 0 0 40px;
  }

  h2 {
    font-family: var(--font-space-grotesk);
    font-weight: 400;
    font-size: 24px;
    margin: 0 0 16px;
    padding-top: 46px;
    border-top: 1px solid rgba(244, 232, 214, 0.08);
  }

  section:first-of-type h2 {
    padding-top: 0;
    border-top: none;
  }

  p {
    font-size: 15px;
    line-height: 1.7;
    color: #d8cbb4;
    margin: 0 0 14px;
  }

  ul {
    font-size: 15px;
    line-height: 1.7;
    color: #d8cbb4;
    padding-left: 20px;
    margin: 0 0 14px;
  }

  li {
    margin-bottom: 6px;
  }

  code {
    font-family: var(--font-mono);
    font-size: 13.5px;
    background: rgba(244, 232, 214, 0.08);
    padding: 2px 6px;
    border-radius: 4px;
    color: #edbb7e;
  }

  .code-block {
    font-family: var(--font-mono);
    font-size: 14px;
    display: block;
    padding: 12px 18px;
    background: #1e2122;
    border: 1px solid rgba(244, 232, 214, 0.14);
    border-radius: 7px;
    margin: 0 0 20px;
    overflow-x: auto;
    white-space: pre;
  }

  .prompt {
    color: #d0802d;
  }

  @media (max-width: 720px) {
    #docs {
      flex-direction: column;
      gap: 30px;
    }

    .toc {
      position: static;
    }

    .toc ul {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 20px;
    }
  }
</style>
